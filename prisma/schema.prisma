generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Auth (NextAuth v5 required tables) ─────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  clients   Client[]
  stripeCustomerId String?
  plan      Plan      @default(STARTER)

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── QA Service Core Models ──────────────────────────────────────────────────

enum Plan {
  STARTER   // $29/mo — 1 site, 3 flows, daily
  PRO       // $99/mo — 3 sites, 10 flows, hourly
  ENTERPRISE // $299/mo — unlimited, 15-min
}

model Client {
  id        String   @id @default(cuid())
  userId    String
  name      String   // e.g. "My Shopify Store"
  url       String   // base URL being monitored
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  flows     TestFlow[]

  @@map("clients")
}

model TestFlow {
  id          String   @id @default(cuid())
  clientId    String
  name        String   // e.g. "Checkout Flow"
  description String?
  steps       String   // JSON array of steps
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client  Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  results TestResult[]

  @@map("test_flows")
}

model TestResult {
  id         String      @id @default(cuid())
  flowId     String
  status     TestStatus
  durationMs Int?
  error      String?     // human-readable error message
  screenshot String?     // path to screenshot file
  rawLog     String?     // full JSON log
  ranAt      DateTime    @default(now())

  flow TestFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId, ranAt])
  @@map("test_results")
}

enum TestStatus {
  PASS
  FAIL
  ERROR   // test runner crashed
  SKIP    // flow inactive
}

model Incident {
  id          String         @id @default(cuid())
  flowId      String
  title       String
  description String
  status      IncidentStatus @default(OPEN)
  createdAt   DateTime       @default(now())
  resolvedAt  DateTime?
  alertSent   Boolean        @default(false)

  @@index([flowId])
  @@map("incidents")
}

enum IncidentStatus {
  OPEN
  RESOLVED
}

model AlertConfig {
  id       String  @id @default(cuid())
  userId   String  @unique
  email    Boolean @default(true)
  telegram String? // chat ID
  slack    String? // webhook URL

  @@map("alert_configs")
}
